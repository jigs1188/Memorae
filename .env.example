# ─────────────────────────────────────────────────────────────
#  Memorae – Personal Memory Query Engine
#  Environment Configuration
#
#  Copy this file to .env and fill in your API key(s).
#  You only need ONE of the two providers below.
# ─────────────────────────────────────────────────────────────

# ── Choose your LLM provider ──────────────────────────────────
# Options: "openai"  |  "gemini"
# If not set, the system auto-detects based on which key is present.
LLM_PROVIDER=openai

# ── OpenAI ────────────────────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...your-key-here...

# Model to use. Recommended: gpt-4o (best quality for this task)
# Other good options: gpt-4o-mini (cheaper/faster), gpt-4-turbo, gpt-3.5-turbo
OPENAI_MODEL=gpt-4o

# ── Google Gemini ─────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey (FREE tier available)
# The pre-configured key below works on Gemini's free tier.
GEMINI_API_KEY=[GCP_API_KEY]
